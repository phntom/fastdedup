#!/bin/sh
# Scheduled fastdedup run — deduplicate files using reflinks
# Configuration: /etc/default/fastdedup
# Logs: /var/log/fastdedup.log (rotated by logrotate)

set -e

[ -x /usr/bin/fastdedup ] || exit 0

# Defaults
ENABLED=yes
OPTIONS="-q"
MOUNTPOINTS=""
LOG_FILE="/var/log/fastdedup.log"

# Load configuration
if [ -f /etc/default/fastdedup ]; then
    . /etc/default/fastdedup
fi

# Exit if disabled
[ "$ENABLED" = "yes" ] || exit 0

# Auto-detect supported filesystems if no explicit mount points configured
if [ -z "$MOUNTPOINTS" ]; then
    MOUNTPOINTS=$(findmnt -rn -t btrfs,xfs,zfs -o TARGET 2>/dev/null || true)
fi

[ -z "$MOUNTPOINTS" ] && exit 0

# Skip if another instance is already running
LOCK_FILE="/var/lock/fastdedup.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    exit 0
fi

# Build extra options
EXTRA_OPTS=""
if [ -n "$MIN_SIZE" ]; then
    EXTRA_OPTS="$EXTRA_OPTS --min-size=$MIN_SIZE"
fi

# Deduplicate each mount point, logging output
for mp in $MOUNTPOINTS; do
    if [ -n "$LOG_FILE" ]; then
        /usr/bin/fastdedup $OPTIONS $EXTRA_OPTS "$mp" 2>>"$LOG_FILE" || true
    else
        /usr/bin/fastdedup $OPTIONS $EXTRA_OPTS "$mp" || true
    fi
done
